<jasperReport name="VendaRelatorio" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0fd6d31a-8a8a-4ead-b245-53a933061b9e">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SisCom"/>
	<property name="com.jaspersoft.studio.report.description" value=""/>
	<parameter name="dataInicial" class="java.sql.Date"/>
	<parameter name="dataFinal" class="java.sql.Date"/>
	<parameter name="clienteId" class="java.lang.Integer"/>
	<query language="SQL"><![CDATA[SELECT
    v.id,
    v.datavenda,
    c.nome AS cliente,
    p.nome AS produto,
    vp.quantidade,
    vp.valorunitario,
    (vp.quantidade * vp.valorunitario) AS subtotal,
    v.valortotal

FROM venda v

JOIN cliente c
    ON c.id = v.cliente_id

JOIN vendaproduto vp
    ON vp.venda_id = v.id

JOIN produto p
    ON p.id = vp.produto_id

WHERE
    v.datavenda BETWEEN $P{dataInicial} AND $P{dataFinal}
    AND (
        $P{clienteId} IS NULL
        OR c.id = $P{clienteId}
    )

ORDER BY
    v.datavenda,
    v.id;]]></query>
