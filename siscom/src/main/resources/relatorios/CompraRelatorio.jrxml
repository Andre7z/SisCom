<jasperReport name="CompraRelatorio" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a6e6dfdf-5b2d-4953-aa1b-98e8fa26f5b4">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SisCom"/>
	<parameter name="dataInicial" class="java.sql.Date"/>
	<parameter name="dataFinal" class="java.sql.Date"/>
	<parameter name="fornecedorId" class="java.lang.Integer"/>
	<query language="SQL"><![CDATA[SELECT
    c.id,
    c.datacompra,
    f.nomefantasia AS fornecedor,
    p.nome AS produto,
    cp.quantidade,
    cp.valorunitario,
    (cp.quantidade * cp.valorunitario) AS subtotal,
    c.valortotal

FROM compra c

JOIN fornecedor f
    ON f.id = c.fornecedor_id

JOIN compraproduto cp
    ON cp.compra_id = c.id

JOIN produto p
    ON p.id = cp.produto_id

WHERE
    c.datacompra BETWEEN $P{dataInicial} AND $P{dataFinal}
    AND (
        $P{fornecedorId} IS NULL
        OR f.id = $P{fornecedorId}
    )

ORDER BY
    c.datacompra,
    c.id;]]></query>
