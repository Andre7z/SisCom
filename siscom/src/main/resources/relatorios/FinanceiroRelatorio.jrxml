<jasperReport name="FinanceiroRelatorio" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="1f1b7dab-6ad1-41fa-9633-778ce43e40c1">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SisCom"/>
	<parameter name="dataInicial" class="java.sql.Date"/>
	<parameter name="dataFinal" class="java.sql.Date"/>
	<query language="SQL"><![CDATA[SELECT
    f.id,
    f.dataconta,
    f.valortotal,

    CASE
        WHEN f.pagaroureceber = 0 THEN 'PAGAR'
        ELSE 'RECEBER'
    END AS tipo,

    tc.descricao AS tipo_conta,
    fp.nome AS forma_pagamento,
    c.nome AS cliente,
    fo.nomefantasia AS fornecedor

FROM financeiro f

LEFT JOIN cliente c
    ON c.id = f.cliente_id

LEFT JOIN fornecedor fo
    ON fo.id = f.fornecedor_id

LEFT JOIN tipoconta tc
    ON tc.id = f.tipo_conta_id

LEFT JOIN formapagamento fp
    ON fp.id = f.forma_pagamento_id

WHERE
    f.dataconta BETWEEN $P{dataInicial} AND $P{dataFinal}

ORDER BY
    f.dataconta,
    f.id;]]></query>
